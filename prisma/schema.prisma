generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  userId    String
  name      String
  website   String?
  industry  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs      Job[]
  contacts  Contact[]

  @@index([userId])
}

model Job {
  id            String    @id @default(cuid())
  userId        String
  title         String
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])
  companyName   String
  url           String?
  status        String    @default("bookmarked")
  salaryMin     Int?
  salaryMax     Int?
  location      String?
  locationType  String?
  dateApplied   DateTime?
  notes         String?
  resumeVersion String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  activities Activity[]
  tasks      Task[]
  contacts   ContactJob[]

  @@index([userId])
}

model Contact {
  id          String   @id @default(cuid())
  userId      String
  name        String
  email       String?
  phone       String?
  role        String?
  linkedIn    String?
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  companyName String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs       ContactJob[]
  activities Activity[]
  tasks      Task[]

  @@index([userId])
}

model ContactJob {
  id        String  @id @default(cuid())
  contactId String
  jobId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([contactId, jobId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  notes     String?
  date      DateTime @default(now())
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  jobId     String?
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model ResumeProfile {
  userId       String   @id
  fullName     String?
  email        String?
  phone        String?
  location     String?
  linkedinUrl  String?
  portfolioUrl String?
  summary      String?
  rawText      String?
  sourceFileName String?
  sourceFileType String?
  sourceFileSize Int?
  sourceFileData Bytes?
  updatedAt    DateTime @updatedAt

  workExperiences ResumeWorkExperience[]
  educations      ResumeEducation[]
  skills          ResumeSkill[]
}

model ResumeWorkExperience {
  id          String    @id @default(cuid())
  userId      String
  company     String
  title       String
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  bulletsJson Json      @default("[]")
  sortOrder   Int       @default(0)
  profile     ResumeProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
}

model ResumeEducation {
  id        String    @id @default(cuid())
  userId    String
  school    String
  degree    String?
  field     String?
  startDate DateTime?
  endDate   DateTime?
  sortOrder Int       @default(0)
  profile   ResumeProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
}

model ResumeSkill {
  id      String @id @default(cuid())
  userId  String
  skill   String
  profile ResumeProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId])
}

model ResumeDocument {
  id             String   @id @default(cuid())
  userId         String
  title          String
  fullName       String?
  rawText        String?
  sourceFileName String?
  sourceFileType String?
  sourceFileSize Int?
  sourceFileData Bytes?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}
